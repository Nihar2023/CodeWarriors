# Copy to `.env` and fill in values:
#   copy .env.example .env   (Windows PowerShell: Copy-Item .env.example .env)

SECRET_KEY=replace_with_a_long_random_secret

# LLM: set GROQ_API_KEY (free tier) and/or GEMINI_API_KEY.
# If GROQ_API_KEY is set, Groq is used automatically. Do NOT set AI_PROVIDER=gemini unless you want Google only.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Optional: force one provider — groq | gemini (most people should leave this unset)
# AI_PROVIDER=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
